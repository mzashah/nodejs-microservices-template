{
  "name": "nodejs-microservices-template",
  "version": "1.0.0",
  "description": "Production Node.js microservices with API Gateway, Docker, RabbitMQ & service discovery",
  "private": true,
  "workspaces": ["services/*"],
  "scripts": {
    "dev:gateway": "cd services/api-gateway && node index.js",
    "dev:auth": "cd services/auth-service && node index.js",
    "dev:users": "cd services/user-service && node index.js",
    "dev:notify": "cd services/notification-service && node index.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "engines": { "node": ">=20.0.0" },
  "license": "MIT"
}
